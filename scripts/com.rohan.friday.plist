<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.rohan.friday</string>
    <key>ProgramArguments</key>
    <array>
        <string>__FRIDAY_PATH__/scripts/run.sh</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>__FRIDAY_PATH__/friday.log</string>
    <key>StandardErrorPath</key>
    <string>__FRIDAY_PATH__/friday.err.log</string>
</dict>
</plist>
